    <connection>oracle_staging_immo</connection>
    <execute_each_row>N</execute_each_row>
    <limit>0</limit>
    <sql>SELECT
  l.id_bien                         AS id_bien_src,
  l.id_client                       AS id_client_src,
  l.id_agent                        AS id_agent_src,

  TRUNC(l.date_visite_loc)          AS date_visite_loc,
  TRUNC(l.date_loc)                 AS date_loc,

  l.prix_loc                        AS prix_location
FROM rbondaz.location l
WHERE l.date_loc IS NOT NULL
</sql>
