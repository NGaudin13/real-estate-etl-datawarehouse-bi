      <to>Database_lookup_D_AGENT_sk_agent</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Database_lookup_D_AGENT_sk_agent</from>
      <to>Database_lookup_D_BIEN_sk_bien_loc_prix</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Database_lookup_D_BIEN_sk_bien_loc_prix</from>
      <to>Calculator</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Calculator</from>
      <to>Insert_update_F_ACHAT</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Calculator</from>
      <to>Write to log</to>
      <enabled>Y</enabled>
    </hop>
  </order>
