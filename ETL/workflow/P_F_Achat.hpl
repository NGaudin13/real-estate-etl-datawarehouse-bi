    <execute_each_row>N</execute_each_row>
    <limit>0</limit>
    <sql>SELECT
  a.id_bien             AS id_bien_src,
  a.id_client           AS id_client_src,
  a.id_agent            AS id_agent_src,
  TRUNC(a.date_visite_achat) AS date_visite_jour,
  TRUNC(a.date_achat)        AS date_achat_jour,
  a.prix_achat           AS prix_achat
FROM rbondaz.achat a
</sql>
    <variables_active>N</variables_active>
