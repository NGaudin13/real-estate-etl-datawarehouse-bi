      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Table_input_ORA_ETAT</from>
      <to>Stream_lookup_ETAT_BIEN</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Stream_lookup_ETAT_BIEN</from>
      <to>CALC_FLAGS_BIEN</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>CALC_FLAGS_BIEN</from>
      <to>Database_lookup_SK_LOCALISATION</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Database_lookup_SK_LOCALISATION</from>
      <to>Write to log 2</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Database_lookup_SK_LOCALISATION</from>
      <to>Insert_update_D_BIEN</to>
      <enabled>Y</enabled>
    </hop>
  </order>
  <transform>
    <name>CALC_FLAGS_BIEN</name>
    <type>Formula</type>
    <description/>
    <distribute>N</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <formulas>
      <formula>
        <field_name>EST_A_RENOVER</field_name>
        <formula>[ETAT_NOM] = "A RENOVER"

</formula>
        <set_na>N</set_na>
        <value_length>-1</value_length>
        <value_precision>-1</value_precision>
        <value_type>4</value_type>
      </formula>
      <formula>
        <field_name>EST_GARAGE</field_name>
        <formula>[TYPE_NOM] = "GARAGE"
</formula>
        <set_na>N</set_na>
        <value_length>-1</value_length>
        <value_precision>-1</value_precision>
        <value_type>4</value_type>
      </formula>
    </formulas>
    <attributes/>
    <GUI>
      <xloc>432</xloc>
      <yloc>432</yloc>
    </GUI>
  </transform>
