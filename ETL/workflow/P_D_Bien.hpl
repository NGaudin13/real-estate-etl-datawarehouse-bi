    <execute_each_row>N</execute_each_row>
    <limit>0</limit>
    <sql>SELECT
  t.ID_TYPE       AS type_id_src,
  TRIM(t.NOM_TYPE) AS type_nom
FROM RBONDAZ.TYPE_BIEN t
WHERE t.ID_TYPE IS NOT NULL
</sql>
    <variables_active>N</variables_active>
    <attributes/>
    <GUI>
