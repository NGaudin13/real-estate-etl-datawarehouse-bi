      <note>Note globale – Pipeline P_D_DATE

Le pipeline P_D_DATE construit la dimension temporelle D_DATE à partir des dates issues des tables ACHAT et LOCATION du système source Oracle.

Les dates sont dédupliquées puis enrichies par le calcul des attributs calendaires (jour, mois, année, semaine, trimestre, jour de la semaine, indicateur week-end).

Les calculs sont réalisés dans l’ETL afin de garantir la cohérence des indicateurs analytiques.

Le chargement dans MySQL est effectué via une étape Insert / Update basée sur la clé métier date_jour, garantissant un chargement idempotent.

La dimension D_DATE est utilisée par les tables de faits pour les analyses temporelles dans Power BI.</note>
      <width>853</width>
    </notepad>
  </notepads>
  <order>
    <hop>
      <from>Table_input_SRC_ORA_DATES</from>
      <to>Calculator_TRF_CALC_DATE_PARTS</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Calculator_TRF_CALC_DATE_PARTS</from>
      <to>Formula_trimestre_weenend</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Formula_trimestre_weenend</from>
      <to>Write to log 2</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Formula_trimestre_weenend</from>
      <to>Insert_update_OUT_MYSQL_D_DATE</to>
      <enabled>Y</enabled>
    </hop>
  </order>
  <transform>
    <name>Calculator_TRF_CALC_DATE_PARTS</name>
    <type>Calculator</type>
    <description/>
    <distribute>N</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <calculation>
      <calc_type>DAY_OF_MONTH</calc_type>
      <field_a>DATE_JOUR</field_a>
      <field_name>jour</field_name>
      <remove>N</remove>
      <value_length>-1</value_length>
      <value_precision>-1</value_precision>
      <value_type>Integer</value_type>
    </calculation>
    <calculation>
      <calc_type>MONTH_OF_DATE</calc_type>
      <field_a>DATE_JOUR</field_a>
      <field_name>mois</field_name>
      <remove>N</remove>
      <value_length>-1</value_length>
      <value_precision>-1</value_precision>
      <value_type>Integer</value_type>
    </calculation>
    <calculation>
      <calc_type>YEAR_OF_DATE_ISO8601</calc_type>
      <field_a>DATE_JOUR</field_a>
      <field_name>annee</field_name>
      <remove>N</remove>
      <value_length>-1</value_length>
      <value_precision>-1</value_precision>
      <value_type>Integer</value_type>
    </calculation>
    <calculation>
      <calc_type>DAY_OF_WEEK</calc_type>
      <field_a>DATE_JOUR</field_a>
      <field_name>jour_semaine</field_name>
      <remove>N</remove>
      <value_length>-1</value_length>
      <value_precision>-1</value_precision>
      <value_type>Integer</value_type>
    </calculation>
    <calculation>
      <calc_type>WEEK_OF_YEAR_ISO8601</calc_type>
      <field_a>DATE_JOUR</field_a>
      <field_name>semaine_annee</field_name>
      <remove>N</remove>
      <value_length>-1</value_length>
      <value_precision>-1</value_precision>
      <value_type>Integer</value_type>
    </calculation>
    <failIfNoFile>Y</failIfNoFile>
    <attributes/>
    <GUI>
      <xloc>352</xloc>
      <yloc>288</yloc>
    </GUI>
  </transform>
  <transform>
    <name>Formula_trimestre_weenend</name>
    <type>Formula</type>
    <description/>
    <distribute>N</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <formulas>
      <formula>
        <field_name>trimestre</field_name>
        <formula>INT( ( [mois] - 1 ) / 3 ) + 1

</formula>
        <set_na>N</set_na>
        <value_length>-1</value_length>
        <value_precision>-1</value_precision>
        <value_type>5</value_type>
      </formula>
      <formula>
        <field_name>is_weekend</field_name>
        <formula>IF( OR( [jour_semaine] = 1 , [jour_semaine] = 7 ) , 1 , 0 )
</formula>
        <set_na>N</set_na>
        <value_length>-1</value_length>
        <value_precision>-1</value_precision>
        <value_type>5</value_type>
      </formula>
    </formulas>
    <attributes/>
    <GUI>
      <xloc>576</xloc>
      <yloc>288</yloc>
    </GUI>
  </transform>
  <transform>
