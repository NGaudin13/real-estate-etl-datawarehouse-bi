        <field>date_jour</field>
        <name>DATE_JOUR</name>
      </key>
      <schema/>
      <table>d_date</table>
      <value>
        <name>date_jour</name>
        <rename>DATE_JOUR</rename>
        <update>N</update>
      </value>
      <value>
        <name>jour</name>
        <rename>jour</rename>
        <update>Y</update>
      </value>
      <value>
        <name>mois</name>
        <rename>mois</rename>
        <update>Y</update>
      </value>
      <value>
        <name>annee</name>
        <rename>annee</rename>
        <update>Y</update>
      </value>
      <value>
        <name>jour_semaine</name>
        <rename>jour_semaine</rename>
        <update>Y</update>
      </value>
      <value>
        <name>semaine_annee</name>
