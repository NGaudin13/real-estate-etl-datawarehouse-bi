  </transform>
  <transform>
    <name>Table_input_SRC_ORA_DATES</name>
    <type>TableInput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>oracle_staging_immo</connection>
    <execute_each_row>N</execute_each_row>
    <limit>0</limit>
    <sql>SELECT TRUNC(date_jour) AS date_jour
FROM (
  SELECT DATE_VISITE_ACHAT AS date_jour FROM RBONDAZ.ACHAT
  UNION ALL
  SELECT DATE_ACHAT        AS date_jour FROM RBONDAZ.ACHAT
  UNION ALL
  SELECT DATE_VISITE_LOC   AS date_jour FROM RBONDAZ.LOCATION
  UNION ALL
  SELECT DATE_LOC          AS date_jour FROM RBONDAZ.LOCATION
)
WHERE date_jour IS NOT NULL
GROUP BY TRUNC(date_jour)

</sql>
    <variables_active>N</variables_active>
    <attributes/>
    <GUI>
      <xloc>128</xloc>
      <yloc>288</yloc>
    </GUI>
