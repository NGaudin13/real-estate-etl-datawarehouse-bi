      <note>Note globale – Pipeline P_D_LOCALISATION

Le pipeline P_D_LOCALISATION construit la dimension D_LOCALISATION à partir des tables VILLE et DEPARTEMENT du système source Oracle.

Les données de localisation sont nettoyées et harmonisées dans l’ETL, puis enrichies avec la région via une table de mapping dédiée (MAP_DPT_REGION).

La conversion département → région est réalisée par un Database Lookup, séparant clairement la logique métier de la source.

Le chargement dans MySQL est effectué via une étape Insert / Update basée sur la clé métier ID_VILLE_SRC, garantissant un chargement idempotent.

La dimension D_LOCALISATION est utilisée par les dimensions et tables de faits pour les analyses géographiques dans Power BI.</note>
      <width>814</width>
    </notepad>
  </notepads>
  <order>
    <hop>
      <from>Table_input_SRC_ORA_LOCALISATION</from>
      <to>Database_lookup_mapping_region</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Database_lookup_mapping_region</from>
      <to>Write to log</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Database_lookup_mapping_region</from>
      <to>insert_update_D_LOCALISATION</to>
      <enabled>Y</enabled>
    </hop>
  </order>
  <transform>
    <name>Database_lookup_mapping_region</name>
    <type>DBLookup</type>
    <description/>
    <distribute>N</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <cache>N</cache>
    <cache_load_all>N</cache_load_all>
    <cache_size>0</cache_size>
    <connection>MYSQL_entrepot_immo</connection>
    <lookup>
      <eat_row_on_failure>N</eat_row_on_failure>
      <fail_on_multiple>N</fail_on_multiple>
      <key>
        <condition>=</condition>
        <field>id_dpt_src</field>
        <name>ID_DPT_SRC</name>
      </key>
      <table>MAP_DPT_REGION</table>
      <value>
        <name>region_nom</name>
        <rename>REGION_NOM</rename>
        <trim_type>both</trim_type>
        <type>String</type>
      </value>
    </lookup>
    <attributes/>
    <GUI>
      <xloc>432</xloc>
      <yloc>320</yloc>
    </GUI>
  </transform>
  <transform>
    <name>Table_input_SRC_ORA_LOCALISATION</name>
    <type>TableInput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>oracle_staging_immo</connection>
    <execute_each_row>N</execute_each_row>
    <limit>0</limit>
    <sql>SELECT DISTINCT
  v.id_ville        AS id_ville_src,
  TRIM(v.nom_ville) AS ville_nom,
  v.id_dpt          AS id_dpt_src,
  TRIM(d.nom_dpt)   AS dpt_nom
FROM rbondaz.ville v
LEFT JOIN rbondaz.departement d
  ON d.id_dpt = v.id_dpt
WHERE v.id_ville IS NOT NULL
</sql>
    <variables_active>N</variables_active>
    <attributes/>
    <GUI>
      <xloc>160</xloc>
      <yloc>320</yloc>
    </GUI>
  </transform>
  <transform>
    <name>Write to log</name>
    <type>WriteToLog</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <displayHeader>Y</displayHeader>
    <fields>
      <field>
        <name>DPT_NOM</name>
      </field>
      <field>
        <name>ID_DPT_SRC</name>
      </field>
      <field>
        <name>ID_VILLE_SRC</name>
      </field>
      <field>
        <name>REGION_NOM</name>
      </field>
      <field>
        <name>VILLE_NOM</name>
      </field>
    </fields>
    <limitRows>N</limitRows>
    <limitRowsNumber>0</limitRowsNumber>
    <loglevel>Basic</loglevel>
    <attributes/>
    <GUI>
      <xloc>432</xloc>
      <yloc>464</yloc>
    </GUI>
  </transform>
  <transform>
    <name>insert_update_D_LOCALISATION</name>
    <type>InsertUpdate</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <commit>100</commit>
    <connection>MYSQL_entrepot_immo</connection>
    <lookup>
      <key>
        <condition>=</condition>
        <field>id_ville_src</field>
        <name>ID_VILLE_SRC</name>
      </key>
      <schema/>
      <table>D_LOCALISATION</table>
      <value>
        <name>ville_nom</name>
        <rename>VILLE_NOM</rename>
        <update>Y</update>
      </value>
      <value>
        <name>id_dpt_src</name>
        <rename>ID_DPT_SRC</rename>
        <update>Y</update>
      </value>
      <value>
        <name>dpt_nom</name>
        <rename>DPT_NOM</rename>
        <update>Y</update>
      </value>
      <value>
        <name>region_nom</name>
        <rename>REGION_NOM</rename>
        <update>Y</update>
      </value>
      <value>
        <name>id_ville_src</name>
        <rename>ID_VILLE_SRC</rename>
        <update>Y</update>
      </value>
    </lookup>
    <update_bypassed>N</update_bypassed>
    <attributes/>
    <GUI>
      <xloc>672</xloc>
      <yloc>320</yloc>
    </GUI>
  </transform>
  <transform_error_handling>
  </transform_error_handling>
  <attributes/>
</pipeline>
