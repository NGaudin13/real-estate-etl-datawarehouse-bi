  <transform>
    <name>Table_input_SRC_ORA_CLIENT</name>
    <type>TableInput</type>
    <description/>
    <distribute>N</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>oracle_staging_immo</connection>
    <execute_each_row>N</execute_each_row>
    <limit>0</limit>
    <sql>SELECT
  c.ID_CLIENT      AS ID_CLIENT_SRC,
  TRIM(c.NOM_CLIENT)    AS NOM,
  TRIM(c.PRENOM_CLIENT) AS PRENOM,
  c.DATE_NAISSANCE       AS DATE_NAISSANCE,
  c.ID_CIV         AS CIVILITE_ID_SRC,
  c.ID_VILLE       AS ID_VILLE_SRC
FROM RBONDAZ.CLIENT c
WHERE c.ID_CLIENT IS NOT NULL
</sql>
    <variables_active>N</variables_active>
    <attributes/>
    <GUI>
      <xloc>128</xloc>
      <yloc>272</yloc>
    </GUI>
