      <note>Note globale – Pipeline P_D_CLIENT

Le pipeline P_D_CLIENT construit la dimension D_CLIENT à partir de la table CLIENT Oracle.

Les données sont enrichies dans l’ETL par le calcul de l’âge, de la tranche d’âge, de la civilité et du sexe.

Chaque client est rattaché à sa localisation via un Database Lookup vers la dimension D_LOCALISATION, permettant la conversion de l’identifiant de ville source en clé technique SK_LOCALISATION.

Le chargement dans MySQL est réalisé via une étape Insert / Update basée sur la clé métier ID_CLIENT_SRC, garantissant un chargement idempotent sans doublons.

La dimension D_CLIENT est utilisée par les tables de faits pour l’analyse décisionnelle dans Power BI.</note>
      <width>1042</width>
    </notepad>
  </notepads>
  <order>
    <hop>
      <from>Table_input_SRC_ORA_CLIENT</from>
      <to>Get_system_info_date_actuelle</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Get_system_info_date_actuelle</from>
      <to>Calculator_CALC_AGE</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Calculator_CALC_AGE</from>
      <to>Formula_refClient</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Formula_refClient</from>
      <to>Database_lookup_ref_sk_localisation</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Database_lookup_ref_sk_localisation</from>
      <to>Write to log</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Database_lookup_ref_sk_localisation</from>
      <to>Insert_update_dimension_client</to>
      <enabled>Y</enabled>
    </hop>
  </order>
  <transform>
    <name>Calculator_CALC_AGE</name>
    <type>Calculator</type>
    <description/>
    <distribute>N</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <calculation>
      <calc_type>YEAR_OF_DATE_ISO8601</calc_type>
      <field_a>DATE_NAISSANCE</field_a>
      <field_name>ANNEE_NAISSANCE</field_name>
      <remove>N</remove>
      <value_length>-1</value_length>
      <value_precision>-1</value_precision>
      <value_type>Integer</value_type>
    </calculation>
    <calculation>
      <calc_type>YEAR_OF_DATE</calc_type>
      <field_a>CURRENT_DATE</field_a>
      <field_name>CURRENT_YEARS</field_name>
      <remove>N</remove>
      <value_length>-1</value_length>
      <value_precision>-1</value_precision>
      <value_type>Integer</value_type>
    </calculation>
    <calculation>
      <calc_type>SUBTRACT</calc_type>
      <field_a>CURRENT_YEARS</field_a>
      <field_b>ANNEE_NAISSANCE</field_b>
      <field_name>AGE</field_name>
      <remove>N</remove>
      <value_length>-1</value_length>
      <value_precision>-1</value_precision>
      <value_type>Integer</value_type>
    </calculation>
    <failIfNoFile>Y</failIfNoFile>
    <attributes/>
    <GUI>
      <xloc>320</xloc>
      <yloc>272</yloc>
    </GUI>
  </transform>
  <transform>
    <name>Database_lookup_ref_sk_localisation</name>
    <type>DBLookup</type>
    <description/>
    <distribute>N</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <cache>N</cache>
    <cache_load_all>N</cache_load_all>
    <cache_size>0</cache_size>
    <connection>MYSQL_entrepot_immo</connection>
    <lookup>
      <eat_row_on_failure>Y</eat_row_on_failure>
      <fail_on_multiple>N</fail_on_multiple>
      <key>
        <condition>=</condition>
        <field>id_ville_src</field>
        <name>ID_VILLE_SRC</name>
      </key>
      <table>d_localisation</table>
      <value>
        <name>sk_localisation</name>
        <rename>SK_LOCALISATION</rename>
        <trim_type>none</trim_type>
        <type>Integer</type>
      </value>
    </lookup>
    <attributes/>
    <GUI>
      <xloc>544</xloc>
      <yloc>416</yloc>
    </GUI>
  </transform>
  <transform>
    <name>Formula_refClient</name>
    <type>Formula</type>
    <description/>
    <distribute>N</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <formulas>
      <formula>
        <field_name>SEXE</field_name>
        <formula>IF([CIVILITE_ID_SRC]=1,"Masculin",IF([CIVILITE_ID_SRC]=2,"Feminin",""))
</formula>
        <set_na>N</set_na>
        <value_length>-1</value_length>
        <value_precision>-1</value_precision>
        <value_type>2</value_type>
      </formula>
      <formula>
        <field_name>CIVILITE_NOM</field_name>
        <formula>IF([CIVILITE_ID_SRC]=1,"Monsieur",
   IF([CIVILITE_ID_SRC]=2,"Madame",""))
</formula>
        <set_na>N</set_na>
        <value_length>-1</value_length>
        <value_precision>-1</value_precision>
        <value_type>2</value_type>
      </formula>
      <formula>
        <field_name>TRANCHE_AGE</field_name>
        <formula>IF([AGE]&lt;30,"Moins de 30",
   IF([AGE]&lt;=50,"30-50","Plus de 50"))
</formula>
        <set_na>N</set_na>
        <value_length>-1</value_length>
        <value_precision>-1</value_precision>
        <value_type>2</value_type>
      </formula>
    </formulas>
    <attributes/>
    <GUI>
      <xloc>480</xloc>
      <yloc>272</yloc>
    </GUI>
  </transform>
  <transform>
