      </value>
      <value>
        <name>date_naissance</name>
        <rename>DATE_NAISSANCE</rename>
        <update>Y</update>
      </value>
      <value>
        <name>id_client_src</name>
        <rename>ID_CLIENT_SRC</rename>
        <update>Y</update>
      </value>
      <value>
        <name>nom</name>
